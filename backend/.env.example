DATABASE_URL=postgres://user:password@localhost:5432/canvax
HOST=127.0.0.1
PORT=8080
CANVAS_WIDTH=64
CANVAS_HEIGHT=64
MAX_SESSIONS=500

# Optional performance tuning (defaults shown; safe to omit).
# Size of the PostgreSQL connection pool.
DATABASE_MAX_CONNECTIONS=50
# Per-room broadcast buffer; raise if clients log "receiver lagged" under load.
BROADCAST_CAPACITY=8192
# Write-behind pixel persistence worker.
PIXEL_WRITE_BUFFER=10000
PIXEL_FLUSH_INTERVAL_MS=100
PIXEL_FLUSH_MAX_BATCH=500
